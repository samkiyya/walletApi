{
  "info": {
    "_postman_id": "d9ad2fa9-3507-4ba1-aec2-81dea042ff19",
    "name": "WalletApi V1",
    "description": "Production-grade Wallet API with CQRS, idempotency, and concurrency control.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "44807435"
  },
  "item": [
    {
      "name": "Create Wallet",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response JSON\r",
              "let jsonData = pm.response.json();\r",
              "\r",
              "// Safety check\r",
              "if (jsonData.success && jsonData.data && jsonData.data.id) {\r",
              "    let walletId = jsonData.data.id;\r",
              "\r",
              "    // Save to collection variable\r",
              "    pm.collectionVariables.set(\"walletId\", walletId);\r",
              "\r",
              "    console.log(\"Wallet ID saved:\", walletId);\r",
              "} else {\r",
              "    console.error(\"Wallet ID not found in response\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ownerName\": \"sam skyton\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/wallets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "wallets"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Wallet Info",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/wallets/{{walletId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "wallets",
            "{{walletId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get all Wallets Info",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/wallets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "wallets"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Deposit",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 500.00,\n  \"idempotencyKey\": \"dep-{{$guid}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/wallets/{{walletId}}/deposit",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "wallets",
            "{{walletId}}",
            "deposit"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Withdraw",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 250.00,\n  \"idempotencyKey\": \"wd-{{$guid}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/wallets/{{walletId}}/withdraw",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "wallets",
            "{{walletId}}",
            "withdraw"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Transfer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fromWalletId\": \"{{walletId}}\",\n  \"toWalletId\": \"{{targetWalletId}}\",\n  \"amount\": 100.00,\n  \"idempotencyKey\": \"tx-{{$guid}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/wallets/transfers",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "wallets",
            "transfers"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Transactions",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/wallets/{{walletId}}/transactions?page=2&pageSize=20",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "wallets",
            "{{walletId}}",
            "transactions"
          ],
          "query": [
            {
              "key": "page",
              "value": "2"
            },
            {
              "key": "pageSize",
              "value": "20"
            }
          ]
        }
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "walletId",
      "value": "REPLACE_WITH_YOUR_WALLET_ID"
    },
    {
      "key": "targetWalletId",
      "value": "REPLACE_WITH_TARGET_WALLET_ID"
    }
  ]
}